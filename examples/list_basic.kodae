' list[T] basics in Kodae v1
fn main() {
  let xs: list[int] = [1, 2, 3]
  xs.push(4)

  let ys: list[int] = [10, 20]
  xs.append(ys)

  xs[0] = xs[0] + 100

  let last = xs.pop()
  let first = xs.remove(0)

  print("first removed: " + str(first))
  print("last popped: " + str(last))
  print("len: " + str(len(xs)))
}
